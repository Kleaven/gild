# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# ── Next.js ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ───────────────────────────────────────────────────────────────────
# Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWT_SECRET=<jwt-secret>

# Settings → Database → Connection string.
# DATABASE_URL  → Transaction pooler (port 6543, used at runtime by postgres-js).
# DIRECT_URL    → Direct connection (port 5432, used only by migration scripts).
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Developers → API keys in the Stripe dashboard.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_<key>
STRIPE_SECRET_KEY=sk_test_<key>
# Developers → Webhooks → your endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_<secret>

# ── Resend ─────────────────────────────────────────────────────────────────────
# resend.com → API Keys.
RESEND_API_KEY=re_<key>
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Upstash Redis ──────────────────────────────────────────────────────────────
# console.upstash.com → your database → REST API.
UPSTASH_REDIS_REST_URL=https://<db-name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# ── Cloudflare Stream ──────────────────────────────────────────────────────────
# Cloudflare dashboard → My Profile → API Tokens.
CLOUDFLARE_ACCOUNT_ID=<account-id>
CLOUDFLARE_STREAM_API_TOKEN=<token>

# ── Local Supabase Studio (optional) ──────────────────────────────────────────
# Only needed if you want Supabase AI in Studio during `supabase start`.
# OPENAI_API_KEY=sk-<key>
